BOT_TOKEN=your_bot_token_here
ADMIN_USER_IDS=123456789
CHANNEL_ID=-1001234567890
CHANNEL_URL=https://t.me/your_channel
BOT_USERNAME=FancyFaceBot
FAL_KEY=your_fal_key_here
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here

# Robokassa — боевые пароли (из основных Технических настроек)
ROBOKASSA_LOGIN=your_merchant_login
ROBOKASSA_PASSWORD1=your_production_password1
ROBOKASSA_PASSWORD2=your_production_password2
# Тестовые пароли — ОТДЕЛЬНЫЙ набор из раздела "Тестовые пароли" в Технических настройках
ROBOKASSA_TEST_PASSWORD1=your_test_password1
ROBOKASSA_TEST_PASSWORD2=your_test_password2
# ROBOKASSA_IS_TEST=1 — тест, =0 — боевой режим
ROBOKASSA_IS_TEST=1
ROBOKASSA_RESULT_URL=http://YOUR_VPS_IP:8080/robokassa/result
WEBHOOK_PORT=8080
